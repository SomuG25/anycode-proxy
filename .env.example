# ─── AeroLink API Keys (comma-separated — auto-rotates on rate limits) ──────
# Add multiple keys separated by commas. Proxy will rotate through them.
# Get keys from: https://aerolink.lat
AEROLINK_API_KEYS=aero_live_key1_here,aero_live_key2_here

# ─── SearXNG (optional — better web search) ───────────────────────────────────
# If running SearXNG via Docker: http://localhost:8080
# If using Docker Compose (proxy + searxng together): handled automatically
# Leave blank to fall back to DuckDuckGo (no setup needed)
# SEARXNG_URL=http://localhost:8080

# ─── Proxy Port (optional, default: 4141) ────────────────────────────────────
# PORT=4141
